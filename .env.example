# ─────────────────────────────────────────────────────────────────────────────
#  SQL Migration Analyst  –  Environment Configuration
#
#  SETUP (one-time):
#    1. cp .env.example .env
#    2. Fill in ANTHROPIC_API_KEY below
#    3. .env is in .gitignore — it will never be committed
#
#  HOW THE KEY IS USED:
#    The Anthropic SDK reads ANTHROPIC_API_KEY automatically from the
#    environment. You never pass it as a function argument in the code.
#    config/settings.py validates it is present at startup.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY_HERE

# ── Optional overrides (uncomment to change) ─────────────────────────────────

# Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Max agent turns per server before giving up (default: 40)
# AGENT_MAX_TURNS=40

# ODBC driver name — change if you use Driver 18 or a named driver
# ODBC_DRIVER=ODBC Driver 17 for SQL Server

# Connection timeout in seconds (default: 30)
# CONN_TIMEOUT=30
